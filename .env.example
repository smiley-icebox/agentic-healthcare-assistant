# Copy to .env and fill in. The planner/synthesizer need an Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---------------------------------------------------------------
# USE_LLM=0           # template/heuristic only — runs the full app with no API key
# USE_LIVE_SEARCH=0   # skip live MedlinePlus; use the offline corpus only
# DATABASE_URL=postgresql://user:pass@localhost:5432/healthcare   # Postgres backend
# LANGCHAIN_TRACING_V2=true   # opt-in LangSmith tracing
# LANGCHAIN_API_KEY=ls-...
